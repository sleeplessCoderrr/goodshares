{
  "name": "goodshares",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client-service"
  ],
  "scripts": {
    "build": "nest build gateway && nest build auth && nest build user && nest build post",
    "build:gateway": "nest build gateway",
    "build:auth": "nest build auth",
    "build:user": "nest build user",
    "build:post": "nest build post",
    "build:client": "npm run build -w client-service",
    "start:gateway": "node dist/apps/gateway/main",
    "start:auth": "node dist/apps/auth/main",
    "start:user": "node dist/apps/user/main",
    "start:post": "node dist/apps/post/main",
    "dev:gateway": "nest start gateway --watch",
    "dev:auth": "nest start auth --watch",
    "dev:user": "nest start user --watch",
    "dev:post": "nest start post --watch",
    "dev:client": "npm run dev -w client-service",
    "dev:backend": "concurrently -n gateway,auth,user,post -c blue,green,yellow,magenta \"npm:dev:gateway\" \"npm:dev:auth\" \"npm:dev:user\" \"npm:dev:post\"",
    "dev": "concurrently -n gateway,auth,user,post,client -c blue,green,yellow,magenta,cyan \"npm:dev:gateway\" \"npm:dev:auth\" \"npm:dev:user\" \"npm:dev:post\" \"npm:dev:client\"",
    "prisma:generate": "npm run prisma:generate:auth && npm run prisma:generate:user && npm run prisma:generate:post",
    "prisma:generate:auth": "prisma generate --schema=apps/auth/prisma/schema.prisma",
    "prisma:generate:user": "prisma generate --schema=apps/user/prisma/schema.prisma",
    "prisma:generate:post": "prisma generate --schema=apps/post/prisma/schema.prisma",
    "prisma:migrate:auth": "dotenv -e apps/auth/.env -- prisma migrate dev --schema=apps/auth/prisma/schema.prisma",
    "prisma:migrate:user": "dotenv -e apps/user/.env -- prisma migrate dev --schema=apps/user/prisma/schema.prisma",
    "prisma:migrate:post": "dotenv -e apps/post/.env -- prisma migrate dev --schema=apps/post/prisma/schema.prisma",
    "prisma:studio:auth": "dotenv -e apps/auth/.env -- prisma studio --schema=apps/auth/prisma/schema.prisma",
    "prisma:studio:user": "dotenv -e apps/user/.env -- prisma studio --schema=apps/user/prisma/schema.prisma",
    "prisma:studio:post": "dotenv -e apps/post/.env -- prisma studio --schema=apps/post/prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/client": "^6.0.0",
    "axios": "^1.7.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv-cli": "^7.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.0",
    "concurrently": "^9.1.0",
    "jest": "^29.7.0",
    "prisma": "^6.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.0"
  }
}
